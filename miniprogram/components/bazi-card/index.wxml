<!-- 八字卡牌组件 -->
<view class="pillar-item" animation="{{animation}}">
  <view class="pillar-title">{{title}}</view>
  <view class="image-container">
    <image 
      class="pillar-image" 
      src="{{currentImagePath || imagePath}}" 
      mode="aspectFit" 
      bindtap="onCardTap"
      bindload="onImageLoad"
      binderror="onImageError"
      data-pillar="{{pillarName}}"
      animation="{{flipAnimation}}"
      wx:if="{{currentImagePath || imagePath}}" />
    <!-- 单张卡牌加载状态 -->
    <view class="card-loading-overlay" wx:if="{{loading || isLoadingImage}}">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>
    <!-- 不确定时辰问号标识 -->
    <view class="uncertain-time-indicator" wx:if="{{showUncertainIndicator}}">
      <text class="question-mark">?</text>
    </view>
  </view>
</view>
