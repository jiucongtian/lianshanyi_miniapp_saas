<view class="loading-button-wrapper {{block ? 'block' : ''}}">
  <button
    class="damson-button {{size}} {{loading ? 'loading' : ''}} {{customClass}}"
    disabled="{{disabled || loading}}"
    bindtap="onButtonTap"
    hover-class="damson-button--hover"
    hover-stay-time="70"
  >
    <view class="button-content">
      <view wx:if="{{loading}}" class="loading-spinner"></view>
      <text class="button-text">{{loading ? loadingText : buttonText}}</text>
    </view>
  </button>
</view>
