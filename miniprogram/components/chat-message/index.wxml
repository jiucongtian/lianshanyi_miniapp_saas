<!--components/chat-message/index.wxml-->
<view class="message-container {{isUser ? 'user' : 'assistant'}}">
  <!-- 头像 -->
  <view class="avatar {{isUser ? 'user-avatar' : 'assistant-avatar'}}">
    <image
      wx:if="{{isUser}}"
      class="avatar-img"
      src="/static/icons/default-avatar.png"
      mode="aspectFill"
    />
    <text wx:else class="avatar-icon">🧒</text>
  </view>

  <!-- 消息内容 -->
  <view class="message-content" bindtap="onCopyContent">
    <view class="message-bubble">
      <!-- 用户消息：纯文本 -->
      <text
        wx:if="{{isUser}}"
        class="message-text"
        selectable="{{true}}"
      >{{message.content}}</text>

      <!-- 助手消息 - 等待响应中：加载点 -->
      <view wx:elif="{{message.isLoading}}" class="loading-indicator">
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
      </view>

      <!-- 助手消息 - 有 htmlContent：Markdown 渲染 -->
      <view wx:elif="{{message.htmlContent}}" class="message-markdown">
        <rich-text nodes="{{message.htmlContent}}" selectable="{{true}}" />
      </view>

      <!-- 助手消息 - 兜底：纯文本 -->
      <text
        wx:else
        class="message-text"
        selectable="{{true}}"
      >{{message.content}}</text>
    </view>

    <!-- 时间显示 -->
    <view class="message-time">{{message.displayTime}}</view>
  </view>
</view>
