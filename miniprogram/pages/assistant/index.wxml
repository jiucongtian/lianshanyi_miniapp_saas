<!--pages/assistant/index.wxml-->
<view class="assistant-container">
  <!-- 升级提示（无权限时显示） -->
  <view class="upgrade-tip" wx:if="{{showUpgradeTip}}">
    <view class="upgrade-icon">🔮</view>
    <text class="upgrade-title">高级功能</text>
    <text class="upgrade-desc">助学童子是高级功能，仅限管理员和高级用户使用</text>
    <button class="upgrade-btn" bindtap="onUpgrade">前往升级</button>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    id="messageList"
    class="message-list"
    scroll-y="{{true}}"
    scroll-top="{{scrollTop}}"
    scroll-with-animation="{{true}}"
    wx:if="{{hasPermission && !showUpgradeTip}}"
  >
    <!-- 欢迎消息 -->
    <view class="welcome-message" wx:if="{{messages.length === 0}}">
      <!-- 助手头像 -->
      <view class="welcome-avatar">
        <view class="avatar-inner">
          <text class="avatar-icon">🧒</text>
          <text class="avatar-badge">童子</text>
        </view>
      </view>
      <text class="welcome-title">你好，我是助学童子</text>
      <text class="welcome-desc">我可以帮助你解答情感困惑、分析人际关系、探索内心世界。有什么想和我聊聊的吗？</text>

      <!-- 快捷建议 -->
      <view class="quick-suggestions">
        <view class="suggestion-chip" bindtap="onSuggestionTap" data-text="我想了解自己的情感状态">
          情感状态分析
        </view>
        <view class="suggestion-chip" bindtap="onSuggestionTap" data-text="帮我分析一下我和某人的关系">
          关系解读
        </view>
        <view class="suggestion-chip" bindtap="onSuggestionTap" data-text="我最近有些困惑，想找人聊聊">
          心灵对话
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}">
      <chat-message message="{{item}}" />
    </view>

    <!-- 底部占位 -->
    <view class="list-bottom"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area" wx:if="{{hasPermission && !showUpgradeTip}}">
    <view class="new-chat-btn" bindtap="onStartNewConversation" wx:if="{{messages.length > 0}}">
      <text class="btn-icon">✨</text>
    </view>
    <view class="input-wrapper">
      <chat-input
        value="{{inputValue}}"
        disabled="{{sendDisabled}}"
        isTyping="{{isTyping}}"
        placeholder="输入你想问的问题..."
        bind:input="onInputChange"
        bind:send="onSend"
      />
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>