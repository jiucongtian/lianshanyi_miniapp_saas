<!--pages/register/index.wxml-->
<view class="register-container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-content">
      <text class="page-title">欢迎注册连山易</text>
      <text class="page-subtitle">完成注册，解锁更多功能</text>
    </view>
  </view>

  <!-- 注册表单 -->
  <view class="form-container">
    <!-- 头像授权区域 -->
    <view class="avatar-section">
      <view class="avatar-wrapper">
        <image 
          class="user-avatar" 
          src="{{userInfo.avatarUrl || '/static/icons/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="avatar-mask" wx:if="{{!userInfo.avatarUrl}}">
          <text class="avatar-text">点击获取头像</text>
        </view>
      </view>
      <button 
        class="avatar-button {{userInfo.avatarUrl ? 'has-avatar' : ''}}" 
        bindtap="onGetUserProfile"
        disabled="{{loading}}"
      >
        <text class="button-text">{{userInfo.avatarUrl ? '重新获取头像' : '获取微信头像'}}</text>
      </button>
    </view>

    <!-- 基本信息表单 -->
    <view class="form-section">
      <!-- 昵称输入 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">昵称</text>
          <text class="required-mark">*</text>
        </view>
        <input 
          class="form-input"
          type="text"
          placeholder="请输入您的昵称"
          value="{{userInfo.nickName}}"
          bindinput="onNickNameInput"
          maxlength="20"
        />
      </view>

      <!-- 性别选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">性别</text>
        </view>
        <picker 
          class="form-picker"
          mode="selector"
          range="{{genderOptions}}"
          range-key="label"
          value="{{userInfo.gender}}"
          bindchange="onGenderChange"
        >
          <view class="picker-content">
            <text class="picker-text">{{genderOptions[userInfo.gender].label}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>

      <!-- 地区选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">地区</text>
        </view>
        <picker 
          class="form-picker"
          mode="region"
          value="{{userInfo.region}}"
          bindchange="onRegionChange"
        >
          <view class="picker-content">
            <text class="picker-text">
              {{userInfo.region[0] && userInfo.region[1] && userInfo.region[2] ? 
                userInfo.region[0] + ' ' + userInfo.region[1] + ' ' + userInfo.region[2] : 
                '请选择地区'}}
            </text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 用户协议 -->
    <view class="agreement-section">
      <checkbox-group bindchange="onAgreeTermsChange">
        <label class="agreement-item">
          <checkbox value="agree" checked="{{agreeTerms}}" />
          <text class="agreement-text">我已阅读并同意</text>
          <text class="agreement-link" bindtap="onViewTerms">《用户协议》</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 注册按钮 -->
    <view class="button-section">
      <button 
        class="register-button {{formValid ? 'enabled' : 'disabled'}}"
        disabled="{{!formValid || loading}}"
        bindtap="onSubmitRegister"
      >
        <text class="button-text" wx:if="{{!loading}}">完成注册</text>
        <text class="button-text" wx:else>注册中...</text>
      </button>
      
      <button class="skip-button" bindtap="onSkipRegister">
        <text class="button-text">跳过，继续使用临时账户</text>
      </button>
    </view>

    <!-- 注册说明 -->
    <view class="info-section">
      <view class="info-card">
        <text class="info-title">注册后您将获得：</text>
        <view class="benefit-list">
          <view class="benefit-item">
            <text class="benefit-icon">📋</text>
            <text class="benefit-text">创建20个档案</text>
          </view>
          <view class="benefit-item">
            <text class="benefit-icon">📤</text>
            <text class="benefit-text">导出档案数据</text>
          </view>
          <view class="benefit-item">
            <text class="benefit-icon">📱</text>
            <text class="benefit-text">分享给好友</text>
          </view>
          <view class="benefit-item">
            <text class="benefit-icon">💾</text>
            <text class="benefit-text">数据云端保存</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
