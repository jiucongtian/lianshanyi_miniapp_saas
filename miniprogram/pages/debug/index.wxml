<!--pages/debug/index.wxml-->
<view class="debug-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">🔧 调试页面</text>
    <text class="page-subtitle">用于测试各种功能</text>
  </view>

  <!-- 测试功能列表 -->
  <view class="test-list">
    <!-- 配额管理测试 -->
    <view class="test-group">
      <view class="group-header">
        <text class="group-icon">📊</text>
        <text class="group-title">配额管理测试</text>
      </view>
      <view class="test-items">
        <view class="test-item" bindtap="onQuotaFullTest" hover-class="item-hover">
          <text class="item-icon">🚀</text>
          <view class="item-content">
            <text class="item-title">完整测试（所有接口）</text>
            <text class="item-desc">测试配额管理的完整流程</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onQuotaQuickTest" hover-class="item-hover">
          <text class="item-icon">⚡</text>
          <view class="item-content">
            <text class="item-title">快速测试（检查配额）</text>
            <text class="item-desc">快速检查配额信息</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onQuotaCheck" hover-class="item-hover">
          <text class="item-icon">📋</text>
          <view class="item-content">
            <text class="item-title">检查配额</text>
            <text class="item-desc">查看当前配额状态</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onQuotaGrant" hover-class="item-hover">
          <text class="item-icon">➕</text>
          <view class="item-content">
            <text class="item-title">发放配额</text>
            <text class="item-desc">发放10次测试配额</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onQuotaDeduct" hover-class="item-hover">
          <text class="item-icon">➖</text>
          <view class="item-content">
            <text class="item-title">扣除配额</text>
            <text class="item-desc">扣除1次配额</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onQuotaRollback" hover-class="item-hover">
          <text class="item-icon">↩️</text>
          <view class="item-content">
            <text class="item-title">回滚配额</text>
            <text class="item-desc">回滚最近一次扣除的配额</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 支付功能测试 -->
    <view class="test-group">
      <view class="group-header">
        <text class="group-icon">🧪</text>
        <text class="group-title">支付功能测试</text>
      </view>
      <view class="test-items">
        <view class="test-item" bindtap="onTestPayment" hover-class="item-hover">
          <text class="item-icon">💳</text>
          <view class="item-content">
            <text class="item-title">发起测试支付</text>
            <text class="item-desc">测试微信支付V3 API完整流程（¥0.01）</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 用户配额查询 -->
    <view class="test-group">
      <view class="group-header">
        <text class="group-icon">🔍</text>
        <text class="group-title">用户配额查询</text>
      </view>
      <view class="test-items">
        <view class="test-item" bindtap="onQueryUserDrawCardQuota" hover-class="item-hover">
          <text class="item-icon">🎴</text>
          <view class="item-content">
            <text class="item-title">查询用户抽卡配额</text>
            <text class="item-desc">通过用户名或openid查询抽卡配额</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 功能付费订单测试 -->
    <view class="test-group">
      <view class="group-header">
        <text class="group-icon">💰</text>
        <text class="group-title">功能付费订单测试</text>
      </view>
      <view class="test-items">
        <view class="test-item" bindtap="onFunctionPaymentFullTest" hover-class="item-hover">
          <text class="item-icon">🚀</text>
          <view class="item-content">
            <text class="item-title">完整流程测试</text>
            <text class="item-desc">创建订单→支付→回调→配额发放</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onFunctionPaymentQuickTest" hover-class="item-hover">
          <text class="item-icon">⚡</text>
          <view class="item-content">
            <text class="item-title">快速测试（创建+查询）</text>
            <text class="item-desc">创建订单并查询状态</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onFunctionPaymentCreate" hover-class="item-hover">
          <text class="item-icon">📝</text>
          <view class="item-content">
            <text class="item-title">创建功能付费订单</text>
            <text class="item-desc">创建新的功能付费订单</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onFunctionPaymentQuery" hover-class="item-hover">
          <text class="item-icon">🔍</text>
          <view class="item-content">
            <text class="item-title">查询订单状态</text>
            <text class="item-desc">查询订单的当前状态</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onFunctionPaymentVerifyQuota" hover-class="item-hover">
          <text class="item-icon">✅</text>
          <view class="item-content">
            <text class="item-title">验证配额发放</text>
            <text class="item-desc">验证配额是否正确发放</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
        <view class="test-item" bindtap="onFunctionPaymentQuotaInfo" hover-class="item-hover">
          <text class="item-icon">📊</text>
          <view class="item-content">
            <text class="item-title">查看配额信息</text>
            <text class="item-desc">查看当前配额详细信息</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <view class="tip-card">
      <text class="tip-icon">💡</text>
      <text class="tip-text">所有测试结果请查看控制台日志</text>
    </view>
  </view>

  <!-- 查询结果弹窗 -->
  <view class="quota-result-modal" wx:if="{{showQuotaResult}}" catchtap="onCloseQuotaResult">
    <view class="quota-result-content" catchtap="">
      <view class="quota-result-header">
        <text class="quota-result-title">✅ 查询成功</text>
        <text class="quota-result-close" bindtap="onCloseQuotaResult">✕</text>
      </view>
      <scroll-view class="quota-result-body" scroll-y>
        <text class="quota-result-text">{{quotaResultText}}</text>
      </scroll-view>
      <view class="quota-result-footer">
        <button class="quota-result-button" bindtap="onCloseQuotaResult">知道了</button>
      </view>
    </view>
  </view>
</view>

