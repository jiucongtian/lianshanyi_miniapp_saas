<!--pages/debug/index.wxml-->
<view class="debug-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">🔧 调试页面</text>
    <text class="page-subtitle">用于测试各种功能</text>
  </view>

  <!-- 测试功能区域 -->
  <view class="test-section">
    <!-- 配额管理测试 -->
    <view class="test-card">
      <view class="test-header">
        <text class="test-icon">📊</text>
        <text class="test-title">配额管理测试</text>
      </view>
      <view class="test-info">
        <text class="test-desc">测试功能配额管理云函数所有接口</text>
        <text class="test-detail">包含：检查、扣除、发放、回滚</text>
      </view>
      <button class="test-button" bindtap="onTestQuotaManagement" hover-class="button-hover">
        <text class="test-button-text">🚀 开始测试配额</text>
      </button>
    </view>

    <!-- 支付功能测试 -->
    <view class="test-card">
      <view class="test-header">
        <text class="test-icon">🧪</text>
        <text class="test-title">支付功能测试</text>
      </view>
      <view class="test-info">
        <text class="test-desc">测试微信支付V3 API完整流程</text>
        <text class="test-detail">测试金额：¥0.01</text>
      </view>
      <button class="test-button" bindtap="onTestPayment">
        <text class="test-button-text">🚀 发起测试支付</text>
      </button>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <view class="tip-card">
      <text class="tip-icon">💡</text>
      <text class="tip-text">所有测试结果请查看控制台日志</text>
    </view>
  </view>
</view>

