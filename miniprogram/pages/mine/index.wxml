<!--pages/mine/index.wxml-->
<view class="mine-container">
  <!-- 右上角设置按钮 -->
  <view class="settings-button" bindtap="onSettingsTap">
    <text class="settings-icon">⚙️</text>
  </view>

  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <image 
        class="avatar-img" 
        src="{{avatarUrl || '/static/icons/default-avatar.png'}}" 
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo ? (userInfo.nickName || '未设置昵称') : '未注册用户'}}</text>
      <text class="user-level">{{userTypeText}}</text>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-section">
    <!-- 未注册用户或临时用户显示注册按钮 -->
    <view class="action-card" wx:if="{{!userInfo || userInfo.userType === 'guest'}}">
      <view class="action-header">
        <text class="action-title">升级账户</text>
        <text class="action-subtitle">注册后解锁更多功能</text>
      </view>
      <view class="action-buttons">
        <button class="action-button primary" bindtap="onRegister">
          <text class="button-icon">📝</text>
          <text class="button-text">立即注册</text>
        </button>
      </view>
      <view class="benefits-list">
        <view class="benefit-item">
          <text class="benefit-icon">📋</text>
          <text class="benefit-text">创建50个档案</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户详细信息 -->
  <view class="user-details">
    <view class="detail-section">
      <text class="section-title">基本信息</text>
      <view class="detail-item">
        <text class="detail-label">性别</text>
        <text class="detail-value">{{genderText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">手机号</text>
        <text class="detail-value">{{phoneNumberText}}</text>
      </view>
    </view>
    
    <!-- 工具区域 -->
    <view class="tools-section">
      <view class="tool-card" bindtap="onCardViewerTap">
        <view class="tool-icon">🃏</view>
        <view class="tool-info">
          <text class="tool-title">卡牌查看器</text>
          <text class="tool-desc">输入1-60查看对应卡牌</text>
        </view>
        <view class="tool-arrow">›</view>
      </view>
      
      <view class="tool-card" bindtap="onUserManualTap">
        <view class="tool-icon">📖</view>
        <view class="tool-info">
          <text class="tool-title">使用手册</text>
          <text class="tool-desc">查看小程序使用说明</text>
        </view>
        <view class="tool-arrow">›</view>
      </view>
      
      <view class="tool-card" bindtap="onFeedbackTap">
        <view class="tool-icon">💬</view>
        <view class="tool-info">
          <text class="tool-title">反馈与建议</text>
          <text class="tool-desc">告诉我们您的想法</text>
        </view>
        <view class="tool-arrow">›</view>
      </view>
    </view>
    
    <!-- 微信小店入口 -->
    <view class="store-section">
      <view class="store-card" bindtap="onStoreTap">
        <view class="store-icon">🏪</view>
        <view class="store-info">
          <text class="store-title">身心游小店</text>
        </view>
        <view class="store-arrow">›</view>
      </view>
    </view>
    
    <!-- 调试功能区域（开发调试用） -->
    <view class="test-section">
      <!-- 调试页面入口 -->
      <view class="test-card">
        <view class="test-header">
          <text class="test-icon">🔧</text>
          <text class="test-title">调试页面</text>
        </view>
        <view class="test-info">
          <text class="test-desc">进入调试页面测试各种功能</text>
          <text class="test-amount">包含：配额管理、支付等测试</text>
        </view>
        <button class="test-button" bindtap="onDebugTap">
          <text class="test-button-text">🚀 进入调试页面</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 管理员功能区域（仅管理员可见） -->
  <view class="admin-section" wx:if="{{isAdmin}}">
    <view class="admin-header">
      <text class="admin-title">🛡️ 管理员功能</text>
      <text class="admin-role-badge">{{adminRoleName}}</text>
    </view>
    
    <view class="admin-menus">
      <view 
        wx:for="{{adminMenus}}" 
        wx:key="id"
        wx:if="{{item.show}}"
        class="admin-menu-item" 
        bindtap="onAdminMenuTap" 
        data-id="{{item.id}}"
      >
        <view class="menu-icon-wrapper">
          <text class="menu-icon">⚙️</text>
        </view>
        <view class="menu-content">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-container" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
  </view>

</view>
