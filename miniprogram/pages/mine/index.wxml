<!--pages/mine/index.wxml-->
<view class="mine-container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <image 
        class="avatar-img" 
        src="{{userInfo.avatarUrl || '/static/icons/default-avatar.png'}}" 
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '未设置昵称'}}</text>
      <text class="user-level">{{userLevelText}}</text>
    </view>
    <view class="refresh-btn" bindtap="refreshUserInfo">
      <text class="refresh-icon">🔄</text>
    </view>
  </view>

  <!-- 用户详细信息 -->
  <view class="user-details">
    <view class="detail-section">
      <text class="section-title">基本信息</text>
      <view class="detail-item">
        <text class="detail-label">性别</text>
        <text class="detail-value">{{genderText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">地区</text>
        <text class="detail-value">{{locationText}}</text>
      </view>
    </view>

    <view class="detail-section">
      <text class="section-title">账户信息</text>
      <view class="detail-item">
        <text class="detail-label">注册时间</text>
        <text class="detail-value">{{createTimeText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">最后登录</text>
        <text class="detail-value">{{lastLoginTimeText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">账户状态</text>
        <text class="detail-value status-{{userInfo.isActive ? 'active' : 'inactive'}}">
          {{userInfo.isActive ? '正常' : '已停用'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-container" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="refreshUserInfo">重试</button>
  </view>
</view>
