<!--pages/mine/index.wxml-->
<view class="mine-container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <image 
        class="avatar-img" 
        src="{{avatarUrl || '/static/icons/default-avatar.png'}}" 
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '未设置昵称'}}</text>
      <text class="user-level">{{userTypeText}}</text>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-section">
    <!-- 临时用户显示注册按钮 -->
    <view class="action-card" wx:if="{{userInfo.userType === 'guest'}}">
      <view class="action-header">
        <text class="action-title">升级账户</text>
        <text class="action-subtitle">注册后解锁更多功能</text>
      </view>
      <view class="action-buttons">
        <button class="action-button primary" bindtap="onRegister">
          <text class="button-icon">📝</text>
          <text class="button-text">立即注册</text>
        </button>
      </view>
      <view class="benefits-list">
        <view class="benefit-item">
          <text class="benefit-icon">📋</text>
          <text class="benefit-text">创建50个档案</text>
        </view>
      </view>
    </view>

    <!-- 已注册用户显示编辑按钮 -->
    <view class="action-card" wx:else>
      <view class="action-header">
        <text class="action-title">账户管理</text>
        <text class="action-subtitle">管理您的个人信息</text>
      </view>
      <view class="action-buttons">
        <button class="action-button secondary" bindtap="onEditProfile">
          <text class="button-icon">✏️</text>
          <text class="button-text">编辑资料</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 用户详细信息 -->
  <view class="user-details">
    <view class="detail-section">
      <text class="section-title">基本信息</text>
      <view class="detail-item">
        <text class="detail-label">性别</text>
        <text class="detail-value">{{genderText}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">手机号</text>
        <text class="detail-value">{{phoneNumberText}}</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-container" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
  </view>

</view>
