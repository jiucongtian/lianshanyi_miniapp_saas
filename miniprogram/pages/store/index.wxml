<!--pages/store/index.wxml-->
<view class="store-container">
  <!-- 已配置 appid 的情况 -->
  <view wx:if="{{storeAppid}}" class="store-content">
    <!-- 如果有商品，显示商品列表 -->
    <view wx:if="{{hasProducts}}" class="product-list">
      <view 
        wx:for="{{productList}}" 
        wx:key="key" 
        class="product-item"
      >
        <store-product 
          appid="{{storeAppid}}"
          product-id="{{item.id}}"
          bindentersuccess="onProductEnterSuccess"
          bindentererror="onProductEnterError"
        ></store-product>
      </view>
    </view>
    
    <!-- 如果没有配置商品，显示提示 -->
    <view wx:else class="empty-products">
      <view class="empty-content">
        <text class="empty-icon">📦</text>
        <text class="empty-title">暂无商品</text>
        <text class="empty-desc">请在 config/index.js 中配置商品 ID</text>
        <text class="empty-hint">获取方式：小店后台 → 商品管理 → 商品列表 → 规格/编码</text>
      </view>
    </view>
  </view>
  
  <!-- 未配置 appid 时的提示 -->
  <view wx:else class="empty-container">
    <view class="empty-content">
      <text class="empty-icon">🏪</text>
      <text class="empty-title">小店未配置</text>
      <text class="empty-desc">请先在 config/index.js 中配置小店 appid</text>
      <text class="empty-hint">获取方式：小店后台 → 店铺管理 → 基础信息 → 账号信息 → 微信小店ID</text>
    </view>
  </view>
</view>
