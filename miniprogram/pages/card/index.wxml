<view class="page-container">
  <view class="bazi-content">
    <view class="title-header">
      <view class="bazi-title">{{currentProfileName}}</view>
      <view class="profile-entry-button" bindtap="onProfileEntryTap">
        <text class="profile-entry-icon">📋</text>
        <text class="profile-entry-text">牌库</text>
        <view class="profile-count-badge" wx:if="{{profileCount > 0}}">
          <text class="badge-text">{{profileCount}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="loading-icon">⏳</view>
      <view class="loading-text">正在加载卡牌数据...</view>
    </view>

    <!-- 无数据状态 -->
    <view class="empty-state" wx:elif="{{!isDataLoaded}}">
      <view class="empty-icon">🃏</view>
      <view class="empty-text">暂无卡牌数据</view>
      <view class="empty-desc" wx:if="{{profileCount > 0}}">请先选择一个档案</view>
      <view class="empty-desc" wx:else>牌库中还没有卡牌，快来创建第一个吧</view>
      <!-- 当牌库中没有卡牌时，显示新建卡牌按钮 -->
      <view class="create-card-button" wx:if="{{profileCount === 0}}" bindtap="onCreateCardTap">
        <text class="create-card-icon">➕</text>
        <text class="create-card-text">新建卡牌</text>
      </view>
    </view>

    <!-- 卡牌内容 -->
    <view class="pillars-flex" wx:else>
      <!-- 年柱 - 使用组件 -->
      <bazi-card
        id="year-card"
        title="时空关系卡"
        pillar-name="year"
        heavenly-stem="{{yearPillar.heavenlyStem}}"
        earthly-branch="{{yearPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{yearAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 月柱 - 使用组件 -->
      <bazi-card
        id="month-card"
        title="事业关系卡"
        pillar-name="month"
        heavenly-stem="{{monthPillar.heavenlyStem}}"
        earthly-branch="{{monthPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{monthAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 日柱 - 使用组件 -->
      <bazi-card
        id="day-card"
        title="家庭关系卡"
        pillar-name="day"
        heavenly-stem="{{dayPillar.heavenlyStem}}"
        earthly-branch="{{dayPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{dayAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 时柱 - 使用组件 -->
      <bazi-card
        id="time-card"
        title="自我关系卡"
        pillar-name="time"
        heavenly-stem="{{timePillar.heavenlyStem}}"
        earthly-branch="{{timePillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        show-uncertain-indicator="{{isUncertainTime}}"
        animation="{{timeAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />
    </view>
  </view>

  <!-- 图片预览悬浮窗 -->
  <view class="image-preview-overlay" wx:if="{{showImagePreview}}" bindtap="closeImagePreview">
    <image 
      class="preview-image" 
      src="{{previewImagePath}}" 
      mode="aspectFit" 
      bindload="onImageLoad" 
      binderror="onImageError"
      lazy-load="{{false}}"
    />
    <!-- 卡牌描述信息 -->
    <view class="card-description" wx:if="{{previewCardDescription}}" catchtap="">
      <view class="card-desc-text">{{previewCardDescription.description}}</view>
    </view>
  </view>
</view>
