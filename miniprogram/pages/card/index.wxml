<view class="page-container">
  <view class="bazi-content">
    <view class="title-header">
      <view class="bazi-title">{{currentProfileName}}</view>
      <view class="profile-entry-button" bindtap="onProfileEntryTap">
        <text class="profile-entry-icon">📋</text>
        <text class="profile-entry-text">牌库</text>
        <view class="profile-count-badge" wx:if="{{profileCount > 0}}">
          <text class="badge-text">{{profileCount}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="loading-icon">⏳</view>
      <view class="loading-text">正在加载卡牌数据...</view>
    </view>

    <!-- 无数据状态 -->
    <view class="empty-state" wx:elif="{{!isDataLoaded}}">
      <view class="empty-icon">🃏</view>
      <view class="empty-text">暂无卡牌数据</view>
      <view class="empty-desc" wx:if="{{profileCount > 0}}">请先选择一个档案</view>
      <view class="empty-desc" wx:else>牌库中还没有卡牌，快来创建第一个吧</view>
      <!-- 当牌库中没有卡牌时，显示新建卡牌按钮 -->
      <view class="create-card-button" wx:if="{{profileCount === 0}}" bindtap="onCreateCardTap">
        <text class="create-card-icon">➕</text>
        <text class="create-card-text">新建卡牌</text>
      </view>
    </view>

    <!-- 卡牌内容 -->
    <view class="pillars-flex" wx:else>
      <!-- 年柱 - 使用组件 -->
      <bazi-card
        id="year-card"
        title="时空关系卡"
        pillar-name="year"
        heavenly-stem="{{yearPillar.heavenlyStem}}"
        earthly-branch="{{yearPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{yearAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 月柱 - 使用组件 -->
      <bazi-card
        id="month-card"
        title="事业关系卡"
        pillar-name="month"
        heavenly-stem="{{monthPillar.heavenlyStem}}"
        earthly-branch="{{monthPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{monthAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 日柱 - 使用组件 -->
      <bazi-card
        id="day-card"
        title="家庭关系卡"
        pillar-name="day"
        heavenly-stem="{{dayPillar.heavenlyStem}}"
        earthly-branch="{{dayPillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        animation="{{dayAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />

      <!-- 时柱 - 使用组件 -->
      <bazi-card
        id="time-card"
        title="自我关系卡"
        pillar-name="time"
        heavenly-stem="{{timePillar.heavenlyStem}}"
        earthly-branch="{{timePillar.earthlyBranch}}"
        card-back-image="{{cardBackImagePath}}"
        default-show-front="{{false}}"
        show-uncertain-indicator="{{isUncertainTime}}"
        animation="{{timeAnimation}}"
        bind:cardtap="onCardTap"
        bind:imageloaded="onImageLoaded"
        bind:imageloaderror="onImageLoadError"
      />
    </view>

    <!-- 值符盘（仅 premium/admin 可见） -->
    <view class="zhifu-section" wx:if="{{showZhifu && isDataLoaded && zhifuData}}">
      <view class="zhifu-title-row">
        <view class="zhifu-title-line"></view>
        <text class="zhifu-title-text">值 符 盘</text>
        <view class="zhifu-title-line"></view>
      </view>
      <text class="zhifu-subtitle">六 旬 · 四 柱</text>

      <!-- 行优先布局：旬|时柱|日柱|月柱|年柱|年龄 -->
      <view class="zhifu-table">
        <!-- 表头行 -->
        <view class="zhifu-row zhifu-header-row">
          <view class="zhifu-cell-hd zhifu-cell-xun">旬</view>
          <view class="zhifu-cell-hd zhifu-cell-value">时柱</view>
          <view class="zhifu-cell-hd zhifu-cell-value">日柱</view>
          <view class="zhifu-cell-hd zhifu-cell-value">月柱</view>
          <view class="zhifu-cell-hd zhifu-cell-value">年柱</view>
          <view class="zhifu-cell-hd zhifu-cell-age">年龄</view>
        </view>
        <!-- 数据行 -->
        <view class="zhifu-row {{item.hour.isHighlighted ? 'zhifu-row-highlighted' : ''}}" wx:for="{{zhifuData.rows}}" wx:key="index">
          <!-- 旬 -->
          <view class="zhifu-cell zhifu-cell-xun">
            <text class="zhifu-cell-text zhifu-text-meta">{{item.xun}}</text>
          </view>
          <!-- 时柱 -->
          <view class="zhifu-cell zhifu-cell-value">
            <view class="zhifu-highlight-bg" wx:if="{{item.hour.isHighlighted}}"></view>
            <text class="zhifu-cell-text {{item.hour.isHighlighted ? 'zhifu-text-highlighted' : ''}} zhifu-type-{{item.hour.type}}">{{item.hour.name}}</text>
          </view>
          <!-- 日柱 -->
          <view class="zhifu-cell zhifu-cell-value">
            <view class="zhifu-highlight-bg" wx:if="{{item.day.isHighlighted}}"></view>
            <text class="zhifu-cell-text {{item.day.isHighlighted ? 'zhifu-text-highlighted' : ''}} zhifu-type-{{item.day.type}}">{{item.day.name}}</text>
          </view>
          <!-- 月柱 -->
          <view class="zhifu-cell zhifu-cell-value">
            <view class="zhifu-highlight-bg" wx:if="{{item.month.isHighlighted}}"></view>
            <text class="zhifu-cell-text {{item.month.isHighlighted ? 'zhifu-text-highlighted' : ''}} zhifu-type-{{item.month.type}}">{{item.month.name}}</text>
          </view>
          <!-- 年柱 -->
          <view class="zhifu-cell zhifu-cell-value">
            <view class="zhifu-highlight-bg" wx:if="{{item.year.isHighlighted}}"></view>
            <text class="zhifu-cell-text {{item.year.isHighlighted ? 'zhifu-text-highlighted' : ''}} zhifu-type-{{item.year.type}}">{{item.year.name}}</text>
          </view>
          <!-- 年龄 -->
          <view class="zhifu-cell zhifu-cell-age">
            <text class="zhifu-cell-text zhifu-text-age">{{item.ageRange}}</text>
          </view>
        </view>
      </view>

      <view class="zhifu-legend">
        <view class="zhifu-legend-dot"></view>
        <text class="zhifu-legend-text">朱标即本柱当下所在旬</text>
      </view>
    </view>
  </view>

  <!-- 图片预览悬浮窗 -->
  <view class="image-preview-overlay" wx:if="{{showImagePreview}}" bindtap="closeImagePreview">
    <image 
      class="preview-image {{previewImageTouching ? 'touching' : ''}}" 
      style="transform: {{previewImageTransformStyle}}"
      src="{{previewImagePath}}" 
      mode="aspectFill" 
      bindload="onImageLoad" 
      binderror="onImageError"
      bindtouchstart="onPreviewTouchStart"
      bindtouchmove="onPreviewTouchMove"
      bindtouchend="onPreviewTouchEnd"
      catchtouchmove="onPreviewTouchMove"
      lazy-load="{{false}}"
    />
    <!-- 卡牌描述信息 -->
    <view class="card-description" wx:if="{{previewCardDescription}}" catchtap="">
      <view class="card-desc-text">{{previewCardDescription.description}}</view>
    </view>
  </view>
</view>
