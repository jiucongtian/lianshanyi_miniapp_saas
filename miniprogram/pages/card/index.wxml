<view class="page-container">
  <view class="bazi-content">
    <view class="bazi-title">{{currentProfileName}}</view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="loading-icon">⏳</view>
      <view class="loading-text">正在加载卡牌数据...</view>
    </view>

    <!-- 无数据状态 -->
    <view class="empty-state" wx:elif="{{!isDataLoaded}}">
      <view class="empty-icon">🃏</view>
      <view class="empty-text">暂无卡牌数据</view>
      <view class="empty-desc">请先创建一个档案或选择现有档案</view>
    </view>

    <!-- 卡牌内容 -->
    <view class="pillars-flex" wx:else>
      <!-- 年柱 -->
      <view class="pillar-item" animation="{{yearAnimation}}">
        <view class="pillar-title">时空关系卡</view>
        <view class="image-container">
          <image 
            class="pillar-image" 
            src="{{yearPillar.imagePath}}" 
            mode="aspectFit" 
            bindtap="onImageTap" 
            binderror="onImageError"
            data-pillar="year"
            wx:if="{{yearPillar.imagePath}}" />
          <view class="image-placeholder" wx:if="{{!yearPillar.imagePath && isLoadingImages}}">
            <view class="loading-spinner"></view>
            <view class="loading-text">加载中...</view>
          </view>
        </view>
      </view>

      <!-- 月柱 -->
      <view class="pillar-item" animation="{{monthAnimation}}">
        <view class="pillar-title">事业关系卡</view>
        <view class="image-container">
          <image 
            class="pillar-image" 
            src="{{monthPillar.imagePath}}" 
            mode="aspectFit" 
            bindtap="onImageTap" 
            binderror="onImageError"
            data-pillar="month"
            wx:if="{{monthPillar.imagePath}}" />
          <view class="image-placeholder" wx:if="{{!monthPillar.imagePath && isLoadingImages}}">
            <view class="loading-spinner"></view>
            <view class="loading-text">加载中...</view>
          </view>
        </view>
      </view>

      <!-- 日柱 -->
      <view class="pillar-item" animation="{{dayAnimation}}">
        <view class="pillar-title">家庭关系卡</view>
        <view class="image-container">
          <image 
            class="pillar-image" 
            src="{{dayPillar.imagePath}}" 
            mode="aspectFit" 
            bindtap="onImageTap" 
            binderror="onImageError"
            data-pillar="day"
            wx:if="{{dayPillar.imagePath}}" />
          <view class="image-placeholder" wx:if="{{!dayPillar.imagePath && isLoadingImages}}">
            <view class="loading-spinner"></view>
            <view class="loading-text">加载中...</view>
          </view>
        </view>
      </view>

      <!-- 时柱 -->
      <view class="pillar-item" animation="{{timeAnimation}}">
        <view class="pillar-title">亲子关系卡</view>
        <view class="image-container">
          <image 
            class="pillar-image" 
            src="{{timePillar.imagePath}}" 
            mode="aspectFit" 
            bindtap="onImageTap" 
            binderror="onImageError"
            data-pillar="time"
            wx:if="{{timePillar.imagePath}}" />
          <view class="image-placeholder" wx:if="{{!timePillar.imagePath && isLoadingImages}}">
            <view class="loading-spinner"></view>
            <view class="loading-text">加载中...</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 图片预览悬浮窗 -->
  <view class="image-preview-overlay" wx:if="{{showImagePreview}}" bindtap="closeImagePreview">
    <image 
      class="preview-image" 
      src="{{previewImagePath}}" 
      mode="aspectFit" 
      catchtap="preventClose" 
      bindload="onImageLoad" 
      binderror="onImageError"
      lazy-load="{{false}}"
    />
  </view>
</view>
