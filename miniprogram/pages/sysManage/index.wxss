/* pages/sysManage/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item--active {
  background: #fdf8ec;
}

.menu-icon {
  font-size: 40rpx;
  width: 56rpx;
  text-align: center;
  margin-right: 20rpx;
}

.menu-info {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 8rpx;
}

/* 功能面板 */
.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 搜索类型 */
.search-type-row {
  margin-bottom: 20rpx;
}

.radio-group {
  display: flex;
  flex-direction: row;
}

.radio-label {
  display: flex;
  align-items: center;
  margin-right: 36rpx;
  font-size: 28rpx;
  color: #555;
}

.radio-label radio {
  margin-right: 8rpx;
}

/* 搜索行 */
.search-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
  margin-right: 16rpx;
}

.search-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #b8860b;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 0;
  border: none;
  flex-shrink: 0;
  overflow: hidden;
}

/* 搜索结果 */
.result-list {
  margin-top: 8rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-user-info {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.result-phone {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.result-right {
  display: flex;
  align-items: center;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.result-type-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.type-guest {
  background: #f5f5f5;
  color: #888;
}

.type-normal {
  background: #e8f4fd;
  color: #1a7cbf;
}

.type-student {
  background: #edf7ed;
  color: #2e7d32;
}

.type-premium {
  background: #fff8e1;
  color: #b8860b;
}

.type-admin {
  background: #fce4ec;
  color: #c62828;
}

.change-btn {
  background: #b8860b !important;
  color: #fff !important;
  border-radius: 8rpx !important;
  font-size: 24rpx !important;
  padding: 0 20rpx !important;
  height: 52rpx !important;
  line-height: 52rpx !important;
  border: none !important;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #bbb;
  font-size: 28rpx;
}
