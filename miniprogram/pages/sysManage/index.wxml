<!--pages/sysManage/index.wxml-->
<view class="container">

  <!-- 功能菜单列表 -->
  <view class="menu-section">
    <view
      class="menu-item {{activePanel === item.id ? 'menu-item--active' : ''}}"
      wx:for="{{menuList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onMenuTap"
    >
      <view class="menu-icon">{{item.icon}}</view>
      <view class="menu-info">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-desc">{{item.desc}}</text>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 修改用户类型面板 -->
  <view class="panel" wx:if="{{activePanel === 'updateUserType'}}">
    <view class="panel-title">修改用户类型</view>

    <!-- 搜索方式选择 -->
    <view class="search-type-row">
      <radio-group class="radio-group" bindchange="onSearchTypeChange">
        <label class="radio-label">
          <radio value="0" checked="{{searchType === 'phone'}}" color="#b8860b"/>
          <text>手机号</text>
        </label>
        <label class="radio-label">
          <radio value="1" checked="{{searchType === 'name'}}" color="#b8860b"/>
          <text>用户名</text>
        </label>
      </radio-group>
    </view>

    <!-- 搜索输入框 -->
    <view class="search-row">
      <input
        class="search-input"
        placeholder="{{searchType === 'phone' ? '请输入手机号' : '请输入用户名'}}"
        value="{{searchKeyword}}"
        bindinput="onSearchKeywordInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch" loading="{{searching}}">查询</button>
    </view>

    <!-- 搜索结果 -->
    <view class="result-list" wx:if="{{searchResults.length > 0}}">
      <view class="result-item" wx:for="{{searchResults}}" wx:key="_id">
        <view class="result-user-info">
          <text class="result-name">{{item.nickName || '未设置昵称'}}</text>
          <text class="result-phone">{{item.phoneNumber || '未设置手机号'}}</text>
        </view>
        <view class="result-right">
          <text class="result-type-badge type-{{item.userType}}">{{item.userTypeLabel}}</text>
          <button
            class="change-btn"
            data-user-id="{{item._id}}"
            data-current-type="{{item.userType}}"
            bindtap="onSelectUserType"
            size="mini"
          >修改</button>
        </view>
      </view>
    </view>

    <!-- 无结果提示 -->
    <view class="empty-tip" wx:if="{{!searching && searchResults.length === 0 && searchKeyword}}">
      <text>未找到匹配的用户</text>
    </view>
  </view>

</view>
