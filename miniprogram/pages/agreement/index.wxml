<!--pages/agreement/index.wxml-->
<view class="agreement-container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-content">
      <text class="page-title">身心游卡牌用户协议</text>
      <text class="page-subtitle">成都创畦文化传播有限公司</text>
    </view>
  </view>

  <!-- 协议内容 -->
  <scroll-view class="content-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="content">
      <rich-text class="rich-content" nodes="{{agreementContent}}"></rich-text>
    </view>
  </scroll-view>

  <!-- 底部操作按钮 -->
  <view class="footer-actions">
    <button class="agree-button" bindtap="onAgreeAndClose">
      <text class="button-text">我已阅读并同意</text>
    </button>
  </view>
</view>
