<t-navbar title="智慧洞见" left-arrow bind:click-left="goBack" />

<view class="page-container">
  <!-- 主内容区域 -->
  <view class="main-content">
    <!-- 用户问题显示区域 -->
    <view class="question-container" wx:if="{{question}}">
      <view class="question-label">你的问题</view>
      <view class="question-text">{{question}}</view>
    </view>
    
    <!-- 转圈动画区域 -->
    <view class="mandala-container">
      <view class="mandala">
        <!-- 最外层实心圆环 -->
        <view class="ring ring-outer-1">
          <view class="ring-mark">
            <view class="mark-dot"></view>
          </view>
        </view>
        <!-- 第二层虚线圆环 -->
        <view class="ring ring-outer-2">
          <view class="ring-mark">
            <view class="mark-dot mark-dot-small"></view>
          </view>
        </view>
        <!-- 第三层实心圆环 -->
        <view class="ring ring-outer-3">
          <view class="ring-mark">
            <view class="mark-dot"></view>
          </view>
        </view>
        <!-- 第四层虚线圆环 -->
        <view class="ring ring-outer-4">
          <view class="ring-mark">
            <view class="mark-dot mark-dot-small"></view>
          </view>
        </view>
        <!-- 最内层：天干自转 -->
        <view class="tiangan-container">
          <view class="tiangan-item" wx:for="{{tianGanIndices}}" wx:key="index">
            <text class="tiangan-text">{{tianGan[index]}}</text>
          </view>
        </view>
        <!-- 光晕效果 -->
        <view class="glow-effect"></view>
      </view>
    </view>
    
    <!-- 抽卡区域 -->
    <view class="card-draw-container">
      <!-- 选中框 -->
      <!-- <view class="selected-frame"></view> >
      
      <!-- 卡牌滚动容器 -->
      <view class="cards-scroll-wrapper">
        <view class="cards-scroll" style="transform: translateX({{scrollOffset}}rpx); transition: transform {{transitionDuration}}ms {{transitionTiming}};">
          <view class="card-item {{cardIndex === selectedIndex ? 'selected' : ''}}" wx:for="{{cardList}}" wx:key="key" wx:for-index="cardIndex">
            <view class="card-inner {{cardIndex === selectedIndex && isFlipped ? 'flipped' : ''}}" bindtap="onCardTap" data-is-flipped="{{cardIndex === selectedIndex && isFlipped}}">
              <!-- 卡牌背面 -->
              <view class="card-back">
                <image class="card-back-image" src="/static/card-back.jpg" mode="aspectFill"></image>
              </view>
              <!-- 卡牌正面 -->
              <view class="card-front">
                <!-- 显示卡片图片 -->
                <image 
                  wx:if="{{selectedCardImagePath}}" 
                  class="card-front-image" 
                  src="{{selectedCardImagePath}}" 
                  mode="aspectFill"
                />
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- AI解读结果显示 -->
    <view class="ai-result-container" wx:if="{{aiInterpretation}}">
      <view class="result-title">AI 深度洞察</view>
      <text class="result-content">{{aiInterpretation}}</text>
      
      <!-- 大赏功能区域 -->
      <view class="reward-section">
        <!-- 大赏头部（始终显示） -->
        <view class="reward-header">
          <view class="reward-hint">觉得准?随喜赞赏祈福*+</view>
        </view>
        
        <!-- 红色圆形打赏按钮（默认显示） -->
        <view class="reward-trigger-button" wx:if="{{!showRewardOptions}}">
          <view class="reward-trigger-circle" catchtap="onShowRewardOptions">
            <text class="reward-trigger-text">打赏</text>
          </view>
        </view>
        
        <!-- 金额选择区域（点击打赏按钮后显示） -->
        <view class="reward-options-container" wx:if="{{showRewardOptions}}">
          <!-- 预设金额按钮 -->
          <view class="preset-amounts">
            <view 
              class="preset-amount-item {{selectedRewardAmount === item.amount ? 'selected' : ''}} {{item.recommended ? 'recommended' : ''}}"
              wx:for="{{presetAmounts}}" 
              wx:key="amount"
              bindtap="onSelectPresetAmount"
              data-amount="{{item.amount}}"
            >
              <view class="preset-amount-value">¥{{item.amount}}</view>
              <view class="preset-amount-label">{{item.label}}</view>
              <view class="recommended-tag" wx:if="{{item.recommended}}">推荐</view>
            </view>
          </view>
          
          <!-- 其他金额和随喜按钮 -->
          <view class="reward-actions">
            <button class="custom-amount-button" bindtap="onShowCustomInput">
              其他金额
            </button>
            <button class="reward-submit-button" bindtap="onReward" disabled="{{isRewarding}}">
              随喜 ¥{{selectedRewardAmount}}
            </button>
          </view>
          
          <!-- 自定义金额输入框 -->
          <view class="custom-amount-input-wrapper" wx:if="{{showCustomInput}}">
            <view class="custom-amount-label">请输入赞赏金额（元）</view>
            <input 
              class="custom-amount-input" 
              type="digit" 
              placeholder="请输入金额"
              value="{{customRewardAmount}}"
              bindinput="onCustomAmountInput"
              bindconfirm="onConfirmCustomAmount"
            />
            <view class="custom-amount-buttons">
              <button class="custom-amount-cancel" bindtap="onCancelCustomAmount">取消</button>
              <button class="custom-amount-confirm" bindtap="onConfirmCustomAmount">确定</button>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 咨询真人客服卡片 -->
    <view class="consultation-card" wx:if="{{aiInterpretation}}">
      <view class="consultation-left">
        <view class="consultant-avatar-wrapper">
          <image class="consultant-avatar" src="{{consultantAvatar || '/static/icons/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="consultant-online-dot" wx:if="{{consultantOnline}}"></view>
        </view>
      </view>
      <view class="consultation-middle">
        <view class="consultation-title">咨询真人客服</view>
        <view class="consultation-desc">提供1v1 深度解惑</view>
      </view>
      <view class="consultation-right">
        <button class="consultation-button" bindtap="onConsultLecturer">去咨询 ></button>
      </view>
    </view>

    <!-- 按钮区域 -->
    <view class="button-container">
      <!-- 抽卡按钮：初始显示，抽卡后隐藏 -->
      <loading-button
        wx:if="{{showDrawButton}}"
        id="loading-button-draw"
        theme="primary"
        size="medium"
        block="{{true}}"
        button-text="{{drawButtonText}}"
        loading-text="抽卡中..."
        prevent-duplicate="{{true}}"
        bind:tap="onAnalyzeAnswer"
      />
      <!-- AI解读按钮：抽卡后显示，AI解读完成后隐藏 -->
      <loading-button
        wx:if="{{showInterpretButton}}"
        id="loading-button-interpret"
        theme="secondary"
        size="medium"
        block="{{true}}"
        button-text="{{interpretButtonText}}"
        loading-text="解读中..."
        prevent-duplicate="{{true}}"
        bind:tap="onAIInterpret"
        disabled="{{!selectedCard || !selectedCard.cardName}}"
      />
      <!-- 分享海报按钮：AI解读完成后显示 -->
      <loading-button
        wx:if="{{showShareButton}}"
        id="loading-button-share"
        theme="secondary"
        size="medium"
        block="{{true}}"
        button-text="生成分享海报"
        loading-text="生成中..."
        prevent-duplicate="{{true}}"
        bind:tap="onGeneratePoster"
      />
    </view>
  </view>
</view>

<!-- 隐藏的Canvas画布，用于生成海报 -->
<canvas 
  type="2d" 
  id="posterCanvas" 
  class="poster-canvas"
></canvas>

<!-- 支付弹窗组件 -->
<payment-modal 
  show="{{showPaymentModal}}" 
  text="{{paymentModalText}}"
></payment-modal>

<!-- 卡牌预览组件 -->
<card-preview
  show="{{showCardPreview}}"
  image-path="{{previewImagePath}}"
  description="{{previewCardDescription}}"
  bind:close="onCloseCardPreview"
></card-preview>

<!-- 客服二维码弹窗 -->
<view class="kefu-modal" wx:if="{{showKefuModal}}" catchtap="onCloseKefuModal">
  <view class="kefu-modal-content" catchtap="">
    <view class="kefu-modal-header">
      <text class="kefu-modal-title">添加客服企业微信</text>
      <view class="kefu-modal-close" bindtap="onCloseKefuModal">×</view>
    </view>
    <view class="kefu-modal-body">
      <image class="kefu-qrcode" src="/static/kefu.jpg" mode="aspectFit"></image>
      <view class="kefu-hint">长按二维码添加客服企业微信</view>
    </view>
  </view>
</view>

