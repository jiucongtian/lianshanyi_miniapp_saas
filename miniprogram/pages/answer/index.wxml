<t-navbar title="智慧洞见" left-arrow bind:go-back="goBack" />

<view class="page-container">
  <!-- 主内容区域 -->
  <view class="main-content">
    <!-- 转圈动画区域 -->
    <view class="mandala-container">
      <view class="mandala">
        <!-- 最外层实心圆环 -->
        <view class="ring ring-outer-1">
          <view class="ring-mark">
            <view class="mark-dot"></view>
          </view>
        </view>
        <!-- 第二层虚线圆环 -->
        <view class="ring ring-outer-2">
          <view class="ring-mark">
            <view class="mark-dot mark-dot-small"></view>
          </view>
        </view>
        <!-- 第三层实心圆环 -->
        <view class="ring ring-outer-3">
          <view class="ring-mark">
            <view class="mark-dot"></view>
          </view>
        </view>
        <!-- 第四层虚线圆环 -->
        <view class="ring ring-outer-4">
          <view class="ring-mark">
            <view class="mark-dot mark-dot-small"></view>
          </view>
        </view>
        <!-- 最内层：天干自转 -->
        <view class="tiangan-container">
          <view class="tiangan-item" wx:for="{{tianGanIndices}}" wx:key="index">
            <text class="tiangan-text">{{tianGan[index]}}</text>
          </view>
        </view>
        <!-- 光晕效果 -->
        <view class="glow-effect"></view>
      </view>
    </view>
    
    <!-- 抽卡区域 -->
    <view class="card-draw-container">
      <!-- 选中框 -->
      <!-- <view class="selected-frame"></view> >
      
      <!-- 卡牌滚动容器 -->
      <view class="cards-scroll-wrapper">
        <view class="cards-scroll" style="transform: translateX({{scrollOffset}}rpx); transition: transform {{transitionDuration}}ms {{transitionTiming}};">
          <view class="card-item {{cardIndex === selectedIndex ? 'selected' : ''}}" wx:for="{{cardList}}" wx:key="key" wx:for-index="cardIndex">
            <view class="card-inner {{cardIndex === selectedIndex && isFlipped ? 'flipped' : ''}}">
              <!-- 卡牌背面 -->
              <view class="card-back">
                <image class="card-back-image" src="/static/card-back.jpg" mode="aspectFit"></image>
              </view>
              <!-- 卡牌正面 -->
              <view class="card-front">
                <view class="card-content">
                  <text class="card-number">{{answerNumber}}</text>
                  <text class="card-text">{{question}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 干支输入区域 -->
    <view class="ganzhi-input-container">
      <view class="input-label">干支文字</view>
      <textarea 
        class="ganzhi-textarea"
        placeholder="请输入要解读的干支文字"
        value="{{ganzhiInput}}"
        bindinput="onGanzhiInput"
        maxlength="200"
        auto-height
      />
    </view>

    <!-- AI解读结果显示 -->
    <view class="ai-result-container" wx:if="{{aiInterpretation}}">
      <view class="result-title">AI解读结果</view>
      <view class="result-content">{{aiInterpretation}}</view>
    </view>

    <!-- 按钮区域 -->
    <view class="button-container">
      <button class="btn-primary" bindtap="onAnalyzeAnswer">抽卡</button>
      <button class="btn-secondary" bindtap="onAIInterpret" disabled="{{isInterpreting}}">
        {{isInterpreting ? '解读中...' : 'AI解读'}}
      </button>
    </view>
  </view>
</view>

