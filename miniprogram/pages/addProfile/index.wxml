<t-navbar title="{{pageMode === 'edit' ? '编辑个人信息' : '创建个人信息'}}" left-arrow bind:go-back="goBack" />

<!-- 页面内容 -->
<view class="page-container">
  <!-- 页面标题区域 -->
  <view class="page-header">
    <view class="header-title">{{pageMode === 'edit' ? '编辑个人信息' : '创建个人信息'}}</view>
  </view>

  <!-- 个人信息填写区域 -->
  <view class="form-card">
    <!-- 名字输入 -->
    <view class="form-section">
      <view class="section-header">
        <t-icon name="user" size="20" color="#0052d9" />
        <text class="section-title">基本信息</text>
      </view>
      
      <view class="input-group">
        <view class="input-label">
          名称
          <text class="required">*</text>
        </view>
        <t-input
          value="{{formData.name}}"
          placeholder="请输入您的名称"
          bind:change="onNameChange"
          bind:blur="onNameBlur"
          error="{{nameError}}"
          class="name-input"
        />
        <view wx:if="{{nameError}}" class="error-message">{{nameError}}</view>
      </view>

      <!-- 性别选择 -->
      <view class="input-group">
        <view class="input-label">性别</view>
        <view class="gender-selector">
          <view 
            class="gender-option {{formData.gender === 1 ? 'active' : ''}}"
            bindtap="onGenderSelect"
            data-gender="1"
          >
            <t-icon name="user" size="16" color="{{formData.gender === 1 ? '#fff' : '#666'}}" />
            <text class="gender-text">男</text>
          </view>
          <view 
            class="gender-option {{formData.gender === 0 ? 'active' : ''}}"
            bindtap="onGenderSelect"
            data-gender="0"
          >
            <t-icon name="user" size="16" color="{{formData.gender === 0 ? '#fff' : '#666'}}" />
            <text class="gender-text">女</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 出生信息选择 -->
    <view class="form-section">
      <view class="section-header">
        <t-icon name="time" size="20" color="#0052d9" />
        <text class="section-title">出生信息</text>
      </view>
      
      <!-- 时辰提示信息 -->
      <view class="time-tip" wx:if="{{isUncertainTime}}">
        <text class="tip-text">不记得具体的时辰信息了</text>
      </view>
      
      <!-- 日历类型选择器 -->
      <view class="input-group">
        <view class="input-label">日历类型</view>
        <view class="calendar-type-selector">
          <view 
            class="type-option {{calendarType === 'solar' ? 'active' : ''}}"
            bindtap="onCalendarTypeSelect"
            data-type="solar"
          >
            <t-icon name="calendar" size="16" color="{{calendarType === 'solar' ? '#fff' : '#666'}}" />
            <text class="type-text">公历</text>
          </view>
          <view 
            class="type-option {{calendarType === 'lunar' ? 'active' : ''}}"
            bindtap="onCalendarTypeSelect"
            data-type="lunar"
          >
            <t-icon name="calendar" size="16" color="{{calendarType === 'lunar' ? '#fff' : '#666'}}" />
            <text class="type-text">农历</text>
          </view>
        </view>
      </view>
      
      <!-- 时间输入框 -->
      <view class="input-group">
        <view class="input-label">
          {{calendarType === 'solar' ? '公历时间' : '农历时间'}}
        </view>
        <view class="input-wrapper {{calendarType === 'lunar' ? 'lunar-input-wrapper' : ''}}" bindtap="onInputTap">
          <view class="time-display {{(calendarType === 'solar' ? solarFormatedDateTime : lunarFormatedDateTime) ? 'has-value' : ''}}">
            {{calendarType === 'solar' ? (solarFormatedDateTime || '请选择年月日时') : (lunarFormatedDateTime || '请选择农历年月日时')}}
          </view>
          <t-icon name="chevron-right" size="16" color="#999" />
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-section">
    <loading-button
      id="loading-button"
      theme="primary"
      size="large"
      block="{{true}}"
      disabled="{{!isFormValid}}"
      button-text="{{pageMode === 'edit' ? '更新信息' : '创建信息'}}"
      loading-text="{{pageMode === 'edit' ? '更新中...' : '创建中...'}}"
      prevent-duplicate="{{true}}"
      bind:tap="onSubmit"
    />
  </view>
</view>

<!-- 自定义时间选择器弹出层 -->
<t-popup visible="{{showPicker}}" placement="bottom" bind:visible-change="onPickerClose">
  <view class="custom-picker">
    <!-- 不确定时辰信息勾选框 -->
    <view class="picker-checkbox-section">
      <view class="checkbox-wrapper">
        <checkbox 
          value="uncertainTime"
          checked="{{isUncertainTime}}" 
          bindtap="onCheckboxTap"
          class="uncertain-time-checkbox"
        />
        <text class="checkbox-label">时辰未知</text>
      </view>
    </view>
    
    <view class="picker-header">
      <view class="picker-btn" bindtap="onPickerCancel">取消</view>
      <view class="picker-title">选择时辰</view>
      <view class="picker-btn confirm" bindtap="onPickerConfirm">确定</view>
    </view>
    <picker-view
      value="{{pickerValue}}"
      bindchange="onPickerChange"
      class="picker-view"
      indicator-class="picker-indicator"
    >
      <!-- 年份列 -->
      <picker-view-column>
        <view wx:for="{{yearRange}}" wx:key="index" class="picker-item">{{item}}年</view>
      </picker-view-column>
      <!-- 月份列 -->
      <picker-view-column>
        <view wx:for="{{monthRange}}" wx:key="index" class="picker-item">{{item}}月</view>
      </picker-view-column>
      <!-- 日期列 -->
      <picker-view-column>
        <view wx:for="{{dayRange}}" wx:key="index" class="picker-item">{{item}}日</view>
      </picker-view-column>
      <!-- 时辰列 -->
      <picker-view-column>
        <view wx:for="{{timeMap}}" wx:key="index" class="picker-item">
          {{item}}
        </view>
      </picker-view-column>
    </picker-view>
  </view>
</t-popup>

<!-- 消息提示 -->
<t-message id="t-message" />
