### 3.2 公共模块示例

```javascript
// cloudfunctions/common/userTypeConfig.js
const cloud = require('wx-server-sdk');

cloud.init({ env: cloud.DYNAMIC_CURRENT_ENV });
const db = cloud.database();

let configCache = null;
let cacheTime = null;
const CACHE_DURATION = 5 * 60 * 1000; // 5分钟缓存

/**
 * 获取用户类型配置（带缓存）
 * @param {string} typeCode - 用户类型代码
 * @returns {Promise<Object>} 配置对象
 */
async function getUserTypeConfig(typeCode) {
  // 检查缓存
  if (configCache && cacheTime && (Date.now() - cacheTime < CACHE_DURATION)) {
    if (configCache[typeCode]) {
      console.log('[getUserTypeConfig] 使用缓存配置:', typeCode);
      return configCache[typeCode];
    }
  }
  
  try {
    console.log('[getUserTypeConfig] 从数据库获取配置:', typeCode);
    const result = await db.collection('static_user_types')
      .where({ typeCode })
      .get();
    
    if (result.data.length > 0) {
      const config = result.data[0];
      
      // 更新缓存
      if (!configCache) configCache = {};
      configCache[typeCode] = config;
      cacheTime = Date.now();
      
      return config;
    }
  } catch (error) {
    console.error('[getUserTypeConfig] 获取配置失败:', error);
  }
  
  // 返回默认配置
  return getDefaultConfig(typeCode);
}

/**
 * 获取默认配置
 */
function getDefaultConfig(typeCode) {
  const defaultConfigs = {
    guest: {
      typeCode: 'guest',
      typeName: '临时用户',
      displayName: '临时用户',
      description: '未注册的临时用户，功能受限',
      profileQuota: 3,
      permissions: ['view', 'create_limited']
    },
    normal: {
      typeCode: 'normal',
      typeName: '探索者',
      displayName: '探索者',
      description: '已注册的普通用户，享受基础功能',
      profileQuota: 50,
      permissions: ['view', 'create']
    },
    premium: {
      typeCode: 'premium',
      typeName: '高级用户',
      displayName: '高级用户',
      description: '付费高级用户，享受全部功能',
      profileQuota: -1,
      permissions: ['all']
    }
  };
  
  return defaultConfigs[typeCode] || defaultConfigs.guest;
}

/**
 * 清除缓存
 */
function clearCache() {
  configCache = null;
  cacheTime = null;
}

module.exports = {
  getUserTypeConfig,
  clearCache
};
```

```javascript
// cloudfunctions/common/responseHelper.js
/**
 * 创建成功响应
 */
function success(data, message = '操作成功') {
  return {
    success: true,
    data: data,
    message: message,
    code: 0,
    timestamp: new Date().getTime()
  };
}

/**
 * 创建错误响应
 */
function error(errorMessage, code = -1, data = null) {
  return {
    success: false,
    error: errorMessage,
    code: code,
    data: data,
    timestamp: new Date().getTime()
  };
}

/**
 * 创建分页响应
 */
function paginated(items, total, page, limit) {
  return success({
    items: items,
    total: total,
    page: page,
    limit: limit,
    hasMore: (page * limit) < total
  });
}

module.exports = {
  success,
  error,
  paginated
};
```

### 3.3 云函数使用公共模块

```javascript
// cloudfunctions/userManagement/index.js
const cloud = require('wx-server-sdk');
const { getUserTypeConfig } = require('../common/userTypeConfig');
const { success, error } = require('../common/responseHelper');

cloud.init({ env: cloud.DYNAMIC_CURRENT_ENV });
const db = cloud.database();

exports.main = async (event, context) => {
  const wxContext = cloud.getWXContext();
  const { action, data } = event;
  
  try {
    switch (action) {
      case 'getUserInfo':
        return await getUserInfo(wxContext);
      case 'createUser':
        return await createUser(wxContext, data);
      // ... 其他action
      default:
        return error('未知操作类型');
    }
  } catch (err) {
    console.error('[userManagement] 云函数执行失败:', err);
    return error(err.message || '操作失败');
  }
};

async function getUserInfo(wxContext) {
  const { OPENID } = wxContext;
  
  try {
    const result = await db.collection('users')
      .where({ openid: OPENID, isActive: true })
      .get();
    
    if (result.data.length === 0) {
      return error('用户不存在');
    }
    
    const user = result.data[0];
    
    // 使用公共模块获取配置
    const typeConfig = await getUserTypeConfig(user.userType);
    
    // 构建返回数据
    const userInfo = {
      ...user,
      typeName: typeConfig.typeName,
      displayName: typeConfig.displayName,
      profileQuota: typeConfig.profileQuota,
      permissions: typeConfig.permissions
    };
    
    return success(userInfo, '获取用户信息成功');
  } catch (err) {
    console.error('[getUserInfo] 获取用户信息失败:', err);
    return error('获取用户信息失败');
  }
}
```

## 四、代码复用原则

### 4.1 禁止重复代码

**发现以下情况必须重构：**

1. 相同或相似的函数在多个文件中出现
2. 相同的配置数据在多处定义
3. 相同的数据处理逻辑在多处实现

**正确做法：**
```javascript
// ❌ 错误：在多个文件中重复定义
// file1.js
const USER_TYPES = { GUEST: 'guest', NORMAL: 'normal' };

// file2.js  
const USER_TYPES = { GUEST: 'guest', NORMAL: 'normal' };

// ✅ 正确：定义一次，到处导入
// constants/userTypes.js
const USER_TYPES = { GUEST: 'guest', NORMAL: 'normal' };
module.exports = { USER_TYPES };

// file1.js
const { USER_TYPES } = require('../constants/userTypes');

// file2.js
const { USER_TYPES } = require('../constants/userTypes');
```

### 4.2 提取公共函数

```javascript
// ❌ 错误：重复的数据处理逻辑
// page1.js
const formatted = `${year}年${month}月${day}日 ${hour}:${minute}`;

// page2.js
const formatted = `${year}年${month}月${day}日 ${hour}:${minute}`;

// ✅ 正确：提取到工具函数
