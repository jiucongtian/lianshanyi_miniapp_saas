### 2.2 Bean函数规范（必须遵守）

**所有云函数返回的数据必须通过Bean函数处理**

#### 2.2.1 统一响应Bean

```javascript
// beans/ResponseBean.js
class ResponseBean {
  constructor(cloudResult) {
    this.success = false;
    this.data = null;
    this.error = null;
    this.code = 0;
    this.timestamp = new Date().getTime();
    
    this._parse(cloudResult);
  }
  
  _parse(cloudResult) {
    // 1. 检查云函数调用是否成功
    if (!cloudResult || !cloudResult.result) {
      console.error('[ResponseBean] 云函数调用失败:', cloudResult);
      this.error = '云函数调用失败';
      this.code = -1;
      return;
    }
    
    const result = cloudResult.result;
    
    // 2. 验证必需字段
    if (typeof result.success !== 'boolean') {
      console.error('[ResponseBean] 响应格式错误，缺少success字段:', result);
      this.error = '响应格式错误：缺少success字段';
      this.code = -2;
      return;
    }
    
    // 3. 提取数据
    this.success = result.success;
    this.data = result.data || null;
    this.error = result.error || null;
    this.code = result.code || 0;
  }
  
  // 静态工厂方法
  static fromCloudResult(cloudResult) {
    return new ResponseBean(cloudResult);
  }
  
  // 创建错误响应
  static error(errorMessage, code = -1) {
    const bean = new ResponseBean(null);
    bean.error = errorMessage;
    bean.code = code;
    return bean;
  }
  
  // 创建成功响应
  static success(data, code = 0) {
    const bean = new ResponseBean(null);
    bean.success = true;
    bean.data = data;
    bean.code = code;
    return bean;
  }
}

module.exports = { ResponseBean };
```

#### 2.2.2 数据安全检查

每个Bean类必须实现：
- 字段存在性检查
- 数据类型验证
- 默认值提供
- 详细错误日志

```javascript
// beans/UserBean.js
class UserBean {
  constructor(data) {
    // 提供默认值，避免程序崩溃
    this._id = data._id || '';
    this.openid = data.openid || '';
    this.nickName = data.nickName || '微信用户';
    this.avatarUrl = data.avatarUrl || '';
    this.userType = data.userType || 'guest';
    this.profileQuota = data.profileQuota || 3;
    this.usedProfiles = data.usedProfiles || 0;
    this.permissions = data.permissions || [];
    
    // 验证关键字段
    this._validate(data);
  }
  
  _validate(data) {
    if (!data._id) {
      console.warn('[UserBean] 缺少_id字段');
    }
    
    if (typeof data.profileQuota !== 'number') {
      console.error('[UserBean] profileQuota字段类型错误:', typeof data.profileQuota);
    }
    
    if (!Array.isArray(data.permissions)) {
      console.error('[UserBean] permissions字段类型错误，期望数组');
    }
  }
  
  // 业务方法
  canCreateMore() {
    return this.profileQuota === -1 || this.usedProfiles < this.profileQuota;
  }
  
  getRemainingQuota() {
    return this.profileQuota === -1 
      ? -1 
      : Math.max(0, this.profileQuota - this.usedProfiles);
  }
}

module.exports = { UserBean };
```

### 2.3 Service层规范

#### 2.3.1 基础Service类

所有Service必须继承BaseService：

```javascript
// services/BaseService.js
const { ResponseBean } = require('../beans/ResponseBean');

class BaseService {
  /**
   * 调用云函数（带错误处理）
   */
  async callFunction(name, data) {
    try {
      console.log(`[${name}] 调用云函数:`, data);
      const result = await wx.cloud.callFunction({ name, data });
      console.log(`[${name}] 云函数返回:`, result);
      return ResponseBean.fromCloudResult(result);
    } catch (error) {
      console.error(`[${name}] 云函数调用失败:`, error);
      return ResponseBean.error(error.message || '网络错误');
    }
  }
  
  /**
   * 带重试的云函数调用
   */
  async callFunctionWithRetry(name, data, retryCount = 3) {
    for (let i = 0; i < retryCount; i++) {
      try {
        const result = await this.callFunction(name, data);
        if (result.success) return result;
        
        // 失败但未到最后一次，延迟后重试
        if (i < retryCount - 1) {
          console.log(`[${name}] 第${i + 1}次调用失败，${1000 * (i + 1)}ms后重试`);
          await this._delay(1000 * (i + 1));
        }
      } catch (error) {
        if (i === retryCount - 1) {
          return ResponseBean.error(error.message);
        }
      }
    }
    
    return ResponseBean.error('重试失败');
  }
  
  _delay(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
}

module.exports = { BaseService };
```

#### 2.3.2 具体Service实现规范

```javascript
// services/UserService.js
const { BaseService } = require('./BaseService');
const { UserBean } = require('../beans/UserBean');

class UserService extends BaseService {
  /**
   * 获取用户信息
   * @returns {Promise<ResponseBean>}
   */
  async getUserInfo() {
    const response = await this.callFunction('userManagement', {
      action: 'getUserInfo'
    });
    
    // 成功时将data转换为Bean
    if (response.success && response.data) {
      response.data = new UserBean(response.data);
    }
    
    return response;
  }
  
  /**
   * 检查用户配额
   * @returns {Promise<ResponseBean>}
   */
  async checkQuota() {
    return this.callFunction('userManagement', {
      action: 'checkUserQuota'
    });
  }
  
  /**
   * 升级用户类型
   * @param {string} targetUserType - 目标用户类型
   * @param {Object} registrationData - 注册数据
   * @returns {Promise<ResponseBean>}
   */
  async upgradeUserType(targetUserType, registrationData = null) {
    return this.callFunction('userManagement', {
      action: 'upgradeUserType',
      data: { targetUserType, registrationData }
    });
  }
}

// 导出单例
module.exports = {
  UserService,
  userService: new UserService()
};
```

**Service层规范要点：**
1. 所有Service继承BaseService
2. 方法必须有完整的JSDoc注释
3. 返回值统一为Promise<ResponseBean>
4. 成功时将data转换为对应的Bean类
5. 导出类和单例实例

### 2.4 Controller层规范

```javascript
// controllers/ProfileController.js
const { userService } = require('../services/UserService');
const { profileService } = require('../services/ProfileService');

class ProfileController {
  constructor(page) {
    this.page = page;
  }
  
  /**
   * 初始化页面
   */
  async initialize() {
    await Promise.all([
      this.loadUserInfo(),
      this.loadProfiles()
    ]);
  }
  
  /**
   * 加载用户信息
   */
  async loadUserInfo() {
    const response = await userService.getUserInfo();
    
    if (response.success) {
      const userInfo = response.data; // 已经是UserBean实例
      
      this.page.setData({
        userInfo: userInfo,
        userType: userInfo.userType,
        profileQuota: userInfo.profileQuota,
        usedProfiles: userInfo.usedProfiles,
        canCreateMore: userInfo.canCreateMore()
      });
    } else {
      this._showError('获取用户信息失败：' + response.error);
    }
  }
  
  /**
   * 加载档案列表
   * @param {number} page - 页码
   * @param {number} limit - 每页数量
   */
  async loadProfiles(page = 1, limit = 20) {
    this.page.setData({ loading: true });
    
    const response = await profileService.getProfiles({ page, limit });
    
    if (response.success) {
      this.page.setData({
        profileList: response.data.profiles,
        hasMore: response.data.hasMore,
        page: page
      });
    } else {
      this._showError('获取档案列表失败：' + response.error);
    }
    
    this.page.setData({ loading: false });
  }
  
  /**
   * 删除档案
   * @param {string} profileId - 档案ID
   */
  async deleteProfile(profileId) {
    const confirmed = await this._confirm('确认删除', '删除后无法恢复');
    if (!confirmed) return;
    
    wx.showLoading({ title: '删除中...' });
    
    const response = await profileService.deleteProfile(profileId);
    
    wx.hideLoading();
    
    if (response.success) {
      this._showSuccess('删除成功');
      await this.loadProfiles();
    } else {
      this._showError('删除失败：' + response.error);
    }
  }
  
  // 私有辅助方法
  async _confirm(title, content) {
    return new Promise((resolve) => {
      wx.showModal({
        title,
        content,
        success: (res) => resolve(res.confirm)
      });
    });
  }
  
  _showSuccess(message) {
    wx.showToast({ title: message, icon: 'success' });
  }
  
  _showError(message) {
    wx.showToast({ title: message, icon: 'error' });
  }
}

module.exports = { ProfileController };
```

**Controller层规范要点：**
1. 构造函数接收page实例
2. 所有异步操作都有加载状态
3. 统一的错误处理和提示
4. 私有方法以_开头
5. 不直接操作DOM，通过page.setData更新数据

### 2.5 Page层规范（精简化）

```javascript
// pages/profile/index.js
const { ProfileController } = require('../../controllers/ProfileController');

Page({
  data: {
    profileList: [],
    loading: false,
    userInfo: null,
    canCreateMore: true
  },
  
  onLoad(options) {
    console.log('[ProfilePage] 页面加载');
    this.controller = new ProfileController(this);
    this.controller.initialize();
  },
  
  onPullDownRefresh() {
    this.controller.loadProfiles().then(() => {
      wx.stopPullDownRefresh();
    });
  },
  
  onReachBottom() {
    if (this.data.hasMore && !this.data.loading) {
      const nextPage = this.data.page + 1;
      this.controller.loadProfiles(nextPage);
    }
  },
  
  // 事件处理器直接调用Controller方法
  onProfileTap(e) {
    const profileId = e.currentTarget.dataset.id;
    this.controller.selectProfile(profileId);
  },
  
  onDeleteProfile(e) {
    const profileId = e.currentTarget.dataset.id;
    this.controller.deleteProfile(profileId);
  },
  
  onAddProfile() {
    if (!this.data.canCreateMore) {
      this.controller.showQuotaExceededDialog();
      return;
    }
    
    wx.navigateTo({
      url: '/pages/addProfile/index'
    });
  }
});
```

**Page层规范要点：**
1. 保持轻量级，只处理生命周期和事件绑定
2. 业务逻辑全部委托给Controller
3. 不直接调用Service
4. data只包含视图需要的数据

