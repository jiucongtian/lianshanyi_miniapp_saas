## 六、性能优化原则

### 6.1 数据缓存

```javascript
class ConfigService {
  constructor() {
    this.cache = new Map();
    this.cacheTime = new Map();
    this.CACHE_DURATION = 5 * 60 * 1000; // 5分钟
  }
  
  async getConfig(key) {
    // 检查缓存
    if (this.cache.has(key)) {
      const cacheTime = this.cacheTime.get(key);
      if (Date.now() - cacheTime < this.CACHE_DURATION) {
        return this.cache.get(key);
      }
    }
    
    // 获取新数据
    const data = await this.fetchConfig(key);
    this.cache.set(key, data);
    this.cacheTime.set(key, Date.now());
    
    return data;
  }
}
```

### 6.2 防抖和节流

```javascript
// 防抖：用户停止输入后才执行
function debounce(fn, delay) {
  let timer = null;
  return function(...args) {
    if (timer) clearTimeout(timer);
    timer = setTimeout(() => fn.apply(this, args), delay);
  };
}

// 使用
onSearchInput: debounce(function(e) {
  this.search(e.detail.value);
}, 500)
```
