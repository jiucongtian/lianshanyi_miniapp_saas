# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/lianshanyi_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=change_me_jwt_secret_32chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_GUEST_EXPIRES_IN=30d

# MinIO / Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=lianshanyi
MINIO_PUBLIC_URL=http://localhost:9000/lianshanyi

# SMS Provider: mock | aliyun | tencent
SMS_PROVIDER=mock

# Aliyun SMS (needed if SMS_PROVIDER=aliyun)
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=

# AI Provider: mock | coze
AI_PROVIDER=mock

# Coze (needed if AI_PROVIDER=coze)
# COZE_API_TOKEN=
# COZE_CARD_DRAW_WORKFLOW_ID=
# COZE_DAILY_INSIGHT_WORKFLOW_ID=
# COZE_ASSISTANT_BOT_ID=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SMS_RATE_LIMIT_MAX=5

# Daily insight cron job (only run in one instance)
SINGLE_DAILY_INSIGHT_JOB=true
DAILY_INSIGHT_CRON=0 0 * * *

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug

# First super admin (used by npm run admin:create)
# ADMIN_PHONE=
# ADMIN_PASSWORD=
# ADMIN_USERNAME=
